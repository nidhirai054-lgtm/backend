MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/rideshare?retryWrites=true&w=majority
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
REDIS_URL=redis://localhost:6379/0
FLASK_ENV=development
FLASK_DEBUG=1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Razorpay Payments (get from https://dashboard.razorpay.com)
# Use test keys (rzp_test_*) for development
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# VAPID Keys for Web Push Notifications
# Generate at: https://vapidkeys.com  OR run:
#   python -c "from cryptography.hazmat.primitives.asymmetric.ec import generate_private_key, SECP256R1; from cryptography.hazmat.primitives.serialization import Encoding, PublicFormat, PrivateFormat, NoEncryption; import base64; k=generate_private_key(SECP256R1()); print('PRIVATE:', base64.urlsafe_b64encode(k.private_bytes(Encoding.DER,PrivateFormat.Raw,NoEncryption())).decode()); print('PUBLIC:', base64.urlsafe_b64encode(k.public_key().public_bytes(Encoding.X962,PublicFormat.CompressedPoint)).decode())"
VAPID_PRIVATE_KEY=your_base64url_vapid_private_key
VAPID_PUBLIC_KEY=your_base64url_vapid_public_key
VAPID_CLAIM_EMAIL=mailto:admin@smartride.app
